# Copy to .env and fill in. The real .env is gitignored.

# Local development database (your own Postgres). The Replit prod/dev DBs are
# NOT reachable from outside Replit, so local dev uses a local DB.
DATABASE_URL=postgresql://USER@localhost:5432/naama_mentor_connect

# Any non-empty string for local dev. In production this is injected by Replit.
JWT_SECRET=change-me

# Web push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:you@example.com

# SMTP for outgoing email. Leave SMTP_PASS empty to disable email locally.
SMTP_USER=
SMTP_PASS=
